{
    "name": "sikandarmoyaldev/indian-amount-formatter",
    "description": "A high-performance PHP utility package for formatting Indian currency amounts, percentages, and ranges.",
    "type": "library",
    "license": "MIT",
    "version": "1.1.1",
    "keywords": [
        "india",
        "inr",
        "currency",
        "formatter",
        "rupee",
        "lakh",
        "crore",
        "php",
        "money",
        "formatting"
    ],
    "authors": [
        {
            "name": "Sikandar",
            "email": "hello@sikandarmoyal.dev",
            "homepage": "https://github.com/sikandarmoyaldev",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/sikandarmoyaldev/indian-amount-formatter",
    "support": {
        "issues": "https://github.com/sikandarmoyaldev/indian-amount-formatter/issues",
        "source": "https://github.com/sikandarmoyaldev/indian-amount-formatter"
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Sikandarmoyaldev\\IndianAmountFormatter\\": "packages/php/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sikandarmoyaldev\\IndianAmountFormatter\\Tests\\": "packages/php/tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "readme": "packages/php/README.md"
    }
}
