{
    "name": "sikandarmoyaldev/india-amount-formatter",
    "version": "1.0.0",
    "description": "Indian Rupee formatting utilities for PHP",
    "type": "library",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Sikandarmoyaldev\\IndiaAmountFormatter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sikandarmoyaldev\\IndiaAmountFormatter\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}
